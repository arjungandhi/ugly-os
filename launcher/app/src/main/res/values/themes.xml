<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Platform Material theme so we don't need the AppCompat/Material XML
      dependency. Compose draws the actual UI; this just configures the window.
      windowShowWallpaper lets the system wallpaper show through, like a real launcher.
    -->
    <style name="Theme.UglyOs" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
